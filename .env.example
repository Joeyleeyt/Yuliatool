# ============================================================================
# yulia-video — environment template
# Copy to `.env` and fill in. NEVER commit `.env`.
# Validated at boot by packages/core/src/config/env.ts (zod). Missing/invalid
# vars crash the process immediately — fail fast, never at 2am mid-render.
# ============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# --- Supabase / Postgres -----------------------------------------------------
# DATABASE_URL is the direct pooled Postgres connection (repositories use this).
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
# Browser-exposed Supabase config (must mirror the two values above).
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# --- Upstash Redis (BullMQ + cache) ------------------------------------------
# Use the rediss:// TLS URL from Upstash in prod.
REDIS_URL=redis://localhost:6379

# --- Cloudflare R2 (all binaries) --------------------------------------------
R2_ACCOUNT_ID=replace-me
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET=yulia-video
# Optional public CDN base (custom domain bound to the bucket). Blank => signed URLs only.
R2_PUBLIC_BASE_URL=

# --- OpenAI ------------------------------------------------------------------
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o-2024-11-20
# Faster/cheaper model for the many small per-scene prompt-generation calls.
# Unset => falls back to OPENAI_MODEL.
OPENAI_PROMPT_MODEL=gpt-4o-mini

# --- Deepgram (transcription) ------------------------------------------------
DEEPGRAM_API_KEY=replace-me
DEEPGRAM_MODEL=nova-2

# --- 69Labs (video + image generation) ---------------------------------------
SIXTYNINE_LABS_API_KEY=replace-me
SIXTYNINE_LABS_BASE_URL=https://api.69labs.ai/v1

# --- Worker tuning -----------------------------------------------------------
# Scene generation is I/O-bound (polling 69Labs), so this can run well above
# core count. The real ceiling is 69Labs' per-account queue.
WORKER_CONCURRENCY=12
# How long an idle worker blocks waiting for a job before re-polling Redis.
# Higher = far fewer Redis commands when queues are empty (important on metered
# Redis like Upstash). Woken instantly on enqueue, so no latency cost to active
# work. 30s is a big cut vs BullMQ's 5s default.
WORKER_DRAIN_DELAY_SEC=30
# Max seconds a generation poll loop waits before giving up (Veo3 can be slow).
GENERATION_POLL_TIMEOUT_SEC=1200
# How often the generation stage polls 69Labs for a result. Lower = less dead
# time before a finished scene is picked up. Redis is unmetered, so the floor is
# 69Labs' status-GET rate limit; 2s stays well under it.
GENERATION_POLL_INTERVAL_SEC=2
# Max concurrent per-scene OpenAI prompt-generation calls (bounded for rate limits).
PROMPT_GENERATION_CONCURRENCY=8
# Max concurrent scene composites during the FFmpeg render. Keep <= VM core count
# (performance-4x = 4) to avoid CPU oversubscription.
RENDER_COMPOSITE_CONCURRENCY=4
# Max concurrent R2 asset downloads when staging a render locally.
RENDER_DOWNLOAD_CONCURRENCY=6
# Absolute path to a serif .ttf/.otf for numbered title cards. The worker image
# bundles Cinzel at a Linux path; set this when rendering LOCALLY so ffmpeg's
# drawtext finds a real font (a missing path aborts the render). Leave unset in
# the deployed worker. Windows example: C:\Windows\Fonts\georgia.ttf
# TITLE_CARD_FONT=C:\Windows\Fonts\georgia.ttf
