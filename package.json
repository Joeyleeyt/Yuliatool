{
  "name": "yulia-video",
  "version": "0.1.0",
  "private": true,
  "description": "Production AI YouTube video generation platform (voiceover -> cinematic MP4)",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > packages/db/src/generated/database.types.ts",
    "r2:cors": "node --env-file=.env scripts/r2-cors.mjs",
    "r2:cors:print": "node --env-file=.env scripts/r2-cors.mjs --print"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
